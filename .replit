run = "npm run dev"
modules = ["nodejs-20", "python-3.11"]
hidden = [".config", "package-lock.json"]
entrypoint = "index.html"

[nix]
channel = "stable-24_05"
packages = ["firebase-tools", "zip", "lsof", "psmisc", "nano", "tree"]

[unitTest]
language = "nodejs"

[deployment]
run = ["sh", "-c", "npm run preview"]
build = ["sh", "-c", "npm run build"]
deploymentTarget = "static"
publicDir = "dist"

[[deployment.rewrites]]
from = "/*"
to = "/index.html"

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 3001
externalPort = 5173

[[ports]]
localPort = 4173
externalPort = 3002

[[ports]]
localPort = 4174
externalPort = 3003

[[ports]]
localPort = 4175
externalPort = 4200

[[ports]]
localPort = 4176
externalPort = 5000

[[ports]]
localPort = 5000
externalPort = 8000

[[ports]]
localPort = 5001
externalPort = 8080

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5174
externalPort = 3000

[[ports]]
localPort = 5175
externalPort = 6800

[[ports]]
localPort = 9005
externalPort = 6000

[[ports]]
localPort = 32537
externalPort = 8081
exposeLocalhost = true

[[ports]]
localPort = 61614
externalPort = 8008
exposeLocalhost = true

[workflows]
runButton = "Dev Server"

[[workflows.workflow]]
name = "Dev Server"
author = 40973227
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[agent]
expertMode = true
