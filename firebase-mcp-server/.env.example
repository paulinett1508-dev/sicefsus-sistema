# Firebase MCP Server - Configuração de Ambientes
# =================================================
# 
# Este arquivo serve como modelo para o .env
# Copie este arquivo para .env e preencha com suas credenciais reais
# 
# Para obter as credenciais:
# 1. Acesse o Firebase Console (https://console.firebase.google.com)
# 2. Selecione seu projeto
# 3. Vá em Project Settings (ícone de engrenagem) → Service Accounts
# 4. Clique em "Generate new private key"
# 5. O arquivo JSON baixado contém todas as informações necessárias

# ============================================
# AMBIENTE DE DESENVOLVIMENTO (DEV)
# ============================================

# ID do projeto Firebase (campo "project_id" do JSON)
FIREBASE_DEV_PROJECT_ID=seu-projeto-dev

# Email da service account (campo "client_email" do JSON)
FIREBASE_DEV_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto-dev.iam.gserviceaccount.com

# Chave privada (campo "private_key" do JSON)
# IMPORTANTE: Mantenha as quebras de linha (\n) na chave
FIREBASE_DEV_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"

# URL do Database (opcional, campo "databaseURL" se usar Realtime Database)
FIREBASE_DEV_DATABASE_URL=https://seu-projeto-dev.firebaseio.com


# ============================================
# AMBIENTE DE PRODUÇÃO (PROD)
# ============================================

# ID do projeto Firebase (campo "project_id" do JSON)
FIREBASE_PROD_PROJECT_ID=seu-projeto-prod

# Email da service account (campo "client_email" do JSON)
FIREBASE_PROD_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto-prod.iam.gserviceaccount.com

# Chave privada (campo "private_key" do JSON)
# IMPORTANTE: Mantenha as quebras de linha (\n) na chave
FIREBASE_PROD_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"

# URL do Database (opcional, campo "databaseURL" se usar Realtime Database)
FIREBASE_PROD_DATABASE_URL=https://seu-projeto-prod.firebaseio.com


# ============================================
# CONFIGURAÇÕES DO SERVIDOR (OPCIONAL)
# ============================================

# Porta do servidor Express (padrão: 3001)
PORT=3001

# Tipo de transporte MCP: 'stdio' ou 'http' (padrão: stdio)
MCP_TRANSPORT=stdio
