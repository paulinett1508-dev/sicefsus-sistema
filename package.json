{
  "name": "react-javascript",
  "version": "2.3.56",
  "type": "module",
  "description": "React TypeScript on Replit, using Vite bundler",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:api": "cd api && node server.js",
    "build": "node generate-version.js && vite build",
    "build:dev": "node scripts/auto-increment.js development && vite build --mode development",
    "build:prod": "node scripts/auto-increment.js production && vite build --mode production",
    "build:clean": "rm -rf dist dist-backup && npm run build:prod",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "check-console": "node remove-console-prod.cjs",
    "restore-backup": "rm -rf dist && mv dist-backup dist",
    "analise": "node scripts/analise-runner.cjs",
    "version:sync": "node generate-version.js",
    "version:patch": "node scripts/increment-version.js patch",
    "version:minor": "node scripts/increment-version.js minor",
    "version:major": "node scripts/increment-version.js major"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "terser": "^5.43.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vite-plugin-remove-console": "^2.2.0"
  },
  "dependencies": {
    "@babel/parser": "^7.28.0",
    "@babel/traverse": "^7.28.0",
    "firebase": "^11.9.1",
    "firebase-admin": "^13.4.0",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.537.0",
    "react-router-dom": "^7.6.3",
    "recharts": "^3.0.2"
  }
}